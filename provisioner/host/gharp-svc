#!/bin/sh
# gharp-svc <start|stop|restart|is-active> <slot-id>
# Sole privileged entrypoint for the portal (sudoers grants the portal user
# exactly this binary). Validates strictly — no arg wildcards in sudoers.
set -eu
[ "$#" -eq 2 ] || { echo "usage: gharp-svc <action> <slot-id>" >&2; exit 1; }
action="$1"; slot="$2"
case "$action" in start|stop|restart|is-active) ;; *) echo "bad action" >&2; exit 1 ;; esac
case "$slot" in slot-[0-9]) ;; slot-[0-9][0-9]) ;; slot-[0-9][0-9][0-9]) ;; *) echo "bad slot id" >&2; exit 1 ;; esac
exec /usr/bin/systemctl "$action" "gharp-${slot}.service"
